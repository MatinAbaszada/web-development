{
  "name": "ai-chat-app",
  "version": "1.0.0",
  "type": "module",
  "description": "A static AI chat UI with ESLint and Prettier",
  "scripts": {
    "start": "node server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit:install": "pre-commit install",
    "precommit:run": "pre-commit run --all-files"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.1"
  }
}
